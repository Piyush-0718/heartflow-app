# Database Configuration
MONGODB_URI=mongodb://localhost:27017/heartconnect

# JWT Secret (Change this to a random string)
JWT_SECRET=your-super-secret-jwt-key-change-this-to-random-string

# Gemini API (primary bot replies)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Groq API (fallback when Gemini quota is exhausted)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.1-8b-instant

# Twilio Configuration (for SMS OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Email Configuration (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Grievance Officer
GRIEVANCE_EMAIL=grievance@heartconnect.com
GRIEVANCE_OFFICER_NAME=Legal Officer Name

# App Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
FRONTEND_ORIGINS=http://localhost:3000
TRUST_PROXY=1
PORT=3001
NODE_ENV=development

# Admin Credentials (Initial Setup)
ADMIN_EMAIL=admin@heartconnect.com
ADMIN_PASSWORD=ChangeThisPassword123!
